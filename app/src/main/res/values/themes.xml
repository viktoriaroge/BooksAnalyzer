<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.BooksAnalyzer.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">?android:attr/colorBackground</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_book_animated</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.BooksAnalyzer.App</item>
    </style>

    <style name="Theme.BooksAnalyzer.App" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowLightStatusBar">?attr/isLightTheme</item>
        <item name="android:windowLightNavigationBar">?attr/isLightTheme</item>
    </style>
</resources>